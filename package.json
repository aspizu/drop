{
  "name": "drop",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "build": "pnpm --filter @drop/client build",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-plugin-aspizuism": "^1.0.4",
    "oxlint-tsgolint": "^0.23.0",
    "wrangler": "^4.105.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "warn"
    }
  }
}
